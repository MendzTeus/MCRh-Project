# ── Supabase (server-side only — NEVER expose the service key to the browser) ──
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_SERVICE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# ── Admin panel (/admin) ──
# Shared password the admin types on the login screen.
ADMIN_PASSWORD="a-strong-password"
# Secret used to sign the admin session token (any long random string).
ADMIN_JWT_SECRET="a-long-random-string"

# ── iCal sync & Airbnb check endpoints ──
# Secret required in the x-sync-secret header to trigger /api/sync and
# /api/airbnb-check (cron / manual). Leave unset to disable those endpoints.
SYNC_SECRET="a-long-random-string"

# ── Optional ──
# Port the Express API listens on (defaults to 3001).
# API_PORT="3001"
